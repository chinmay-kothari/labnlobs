# Copy this file to `.env` and fill in values. Never commit `.env` (it is gitignored).
# On Netlify, Vercel, Cloudflare Pages, etc., set the same names in the project’s Environment variables.

# Supabase → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Optional: defaults to "email"
# SUPABASE_TABLE=email
